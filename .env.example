# Copy to .env.local and fill in values.
# OWASP A02 — Cryptographic Failures: see comments below.

# -----------------------------------------------------------------------------
# CLIENT-SAFE (NEXT_PUBLIC_* — embedded in browser bundle)
# Only non-secret values. Supabase anon key is designed for public client use.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.kepton.app
NEXT_PUBLIC_PLAY_STORE_LIVE=false

# -----------------------------------------------------------------------------
# SERVER-ONLY (Vercel env — NEVER prefix with NEXT_PUBLIC_ or EXPO_PUBLIC_)
# -----------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Used only by server routes / webhooks via src/lib/supabase/admin.ts
# Never import admin.ts from client components.

# -----------------------------------------------------------------------------
# OWASP A04 — Rate limiting (Upstash Redis)
# Required in production for distributed limits across Vercel instances.
# Create a free database at https://console.upstash.com/
# -----------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Without Upstash, dev uses in-memory limits (single instance only).

# -----------------------------------------------------------------------------
# OWASP A07 — Apply Supabase auth rate limits + JWT settings (Management API)
# Create token: https://supabase.com/dashboard/account/tokens
# Then run: npm run apply:supabase-auth
# SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token
# -----------------------------------------------------------------------------
# 1. Auth → Email: enable "Confirm email" (never OFF in production)
# 2. Run supabase/rls-policies.sql + production-security.sql in SQL Editor
# 3. Verify RLS on every table before launch (queries in production-security.sql)
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# OWASP A08 — RevenueCat webhook (Authorization header REQUIRED)
# Set the SAME value in RevenueCat dashboard → Webhooks → Authorization header
# REVENUECAT_WEBHOOK_AUTH=Bearer your_long_random_webhook_secret
# Optional HMAC layer: REVENUECAT_WEBHOOK_SIGNING_SECRET=...
# Webhook URL: https://your-domain.com/api/webhooks/revenuecat
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# EXPO / React Native mobile app (separate repo) — EXPO_PUBLIC_* audit rules:
# SAFE:     EXPO_PUBLIC_SUPABASE_URL, EXPO_PUBLIC_SUPABASE_ANON_KEY, store URLs
# FORBIDDEN: service role keys, payment secrets, GROQ/API keys, JWT signing secrets
# Storage:  AsyncStorage — session tokens + UI prefs only. No PII (email, name, etc.)
# OTA:      Use EAS Update for UI-only patches. NEVER OTA auth or payment logic —
#           full store release required. See supabase/integrity-security.sql
# Passwords: Supabase Auth only (bcrypt server-side). Never store passwords locally.
# JWT:      Supabase RS256 only. Do not implement custom token signing.
# Transit:  HTTPS only for all API calls. Never use http:// Supabase URLs.
# -----------------------------------------------------------------------------

# Run public env audit: npm run audit:env

# -----------------------------------------------------------------------------
# OWASP A09 — Security logging (optional Axiom forward from audit-log.ts)
# Vercel: Project → Settings → Log Drains → Axiom or Logtail (free tier)
# AXIOM_TOKEN=your_axiom_ingest_token
# AXIOM_DATASET=kepton-security
# See supabase/monitoring-security.sql for alert query examples
# -----------------------------------------------------------------------------
